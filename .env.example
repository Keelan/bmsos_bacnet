SAAS_BASE_URL=http://127.0.0.1:8765
BOX_ID=box_dev_1
API_TOKEN=test-token

POLL_INTERVAL_SECONDS=3
HEARTBEAT_INTERVAL_SECONDS=15
CONFIG_POLL_INTERVAL_SECONDS=30
REQUEST_TIMEOUT_SECONDS=30

LOCAL_DB_PATH=edge_agent.sqlite
LOG_LEVEL=INFO

BACNET_DEVICE_INSTANCE=59999
# LAN IPv4 only, or full CIDR e.g. 192.168.1.10/24 (then prefix below is ignored for mask)
BACNET_BIND_IP=
# Subnet prefix when BIND_IP has no / (BACpypes3 needs this for broadcast Who-Is)
BACNET_BIND_PREFIX=24
BACNET_UDP_PORT=47808
# Who-Is I-Am: unicast (default, compatible) or broadcast (subnet-wide, for tools like YABE that expect BVLC broadcast)
BACNET_IAM_RESPONSE_MODE=unicast
# BACnet device object model-name (read as Model Name on the Device object)
BACNET_MODEL_NAME=bmOS-edge
# BACnet device object vendor-name
BACNET_VENDOR_NAME=bmsOS
BACNET_MOCK=true

SOFTWARE_VERSION=0.1.17

# Site-local BACnet time (refresh; IANA zone from WEATHER lat/lon in SaaS agent JSON)
SITE_TIME_POLL_INTERVAL_SECONDS=1

# read_device_live job defaults (payload may override)
READ_DEVICE_LIVE_MAX_OBJECTS=500
READ_DEVICE_LIVE_TIMEOUT_SECONDS=120
